{
  "manifest_version": 3,
  "name": "Gemini Fast to Pro",
  "version": "1.0.0",
  "description": "Automatically replaces 'Gemini Fast' with 'Gemini Pro' across the web",
  "permissions": ["content_scripts"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
